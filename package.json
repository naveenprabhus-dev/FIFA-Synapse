{
  "name": "fifa-synapse",
  "private": true,
  "version": "1.0.0",
  "description": "FIFA Synapse: Next-Generation AI-powered Decision Intelligence Platform for Smart Stadiums orchestrating real-time telemetry, crowd flows, concession logistics, accessibility assistance, and responsive safety dispatching.",
  "homepage": "https://ai.studio/build",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/google/ai-studio-build.git"
  },
  "keywords": [
    "fifa-synapse",
    "decision-intelligence",
    "sports-tech",
    "smart-stadiums",
    "artificial-intelligence",
    "google-gemini",
    "react-19",
    "firebase",
    "tailwind-css",
    "accessibility",
    "wcag-aa",
    "real-time-telemetry"
  ],
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.16.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.10"
  }
}
